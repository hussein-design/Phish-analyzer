# Copy to .env for local development. Never commit the real .env file.
# These are first-run SEED values only -- once the app has started once,
# the live source of truth for both keys is the Settings dialog (stored in
# the app_settings DB row), not this file.

APP_HOST=127.0.0.1
APP_PORT=8756
LOG_LEVEL=INFO

VT_API_KEY=
ABUSEIPDB_API_KEY=
